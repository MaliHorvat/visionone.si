# VisionOne portal — primer env spremenljivk
# Kopiraj v .env.local (lokalno) ali v Vercel → Settings → Environment Variables (produkcija).
# NE commitaj pravih ključev v git — samo placeholderji spodaj.

# --- PostgreSQL (Faza 1: Stranke / Paketi / Opomniki) ---
# Primer (Vercel Postgres / Neon / Supabase / lokalni):
# DATABASE_URL="postgresql://user:password@host:5432/visionone?sslmode=require"
DATABASE_URL=

# --- Clerk (legacy / sign-in stran) ---
# Trenutni portal uporablja interni login (admin / geslo123); Clerk je opcijski.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal

# --- Piškotki / sledenje (javna marketing stran) ---
# Opcijsko: če prazno, se skripta ne naloži tudi ob soglasju.
# Meta Pixel (Facebook / Instagram oglasi)
NEXT_PUBLIC_META_PIXEL_ID=
# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Google Ads — oznaka za konverzije (gtag), npr. AW-18157157679 (naloži se ob marketing piškotkih)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# --- Javni kontakt (prikaz na strani) ---
NEXT_PUBLIC_CONTACT_EMAIL=info@visionone.si
# NEXT_PUBLIC_CONTACT_PHONE=+38640123456
# NEXT_PUBLIC_CONTACT_PHONE_DISPLAY=040 123 456
# NEXT_PUBLIC_CONTACT_HOURS=Pon–pet, 8:00–16:00
# NEXT_PUBLIC_CONTACT_ADDRESS=Slovenija

# --- Kontaktni obrazec (ponudbe) ---
CONTACT_FORM_TO=info@visionone.si
CONTACT_FORM_FROM="VisionOne <info@visionone.si>"

# Način A — Resend (PRIPOROČENO za Vercel; če nastavite ključ, ima prednost pred SMTP)
#   POMEMBNO: visionone.si uporablja Cloudflare Email Routing (samo PREJEMANJE pošte),
#   zato klasičen SMTP iz Vercela NE deluje. Za pošiljanje obrazca uporabite Resend:
#   1) Ustvarite račun in dodajte/verificirajte domeno: https://resend.com
#   2) V Cloudflare dodajte DNS zapise, ki jih pokaže Resend (DKIM/SPF).
#   3) Ustvarite API ključ: https://resend.com/api-keys
#   4) Na Vercelu nastavite RESEND_API_KEY in CONTACT_FORM_FROM (verificirana domena).
RESEND_API_KEY=

# Način B — SMTP (samo če imate DEJANSKI izhodni SMTP strežnik; na Vercelu pogosto ne deluje).
# GESLO SAMO v .env.local / Vercel.
#   Vrata 465 → SMTP_SECURE=true (SSL) | Vrata 587 → SMTP_SECURE=false (STARTTLS)
# Lahko uporabite tudi PORTAL_SMTP_* (isti ključi kot na portal.visionone.si).
# SMTP_HOST=mail.visionone.si
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=info@visionone.si
# SMTP_PASSWORD=

# --- Vsebina iz portala (obvezno na produkciji visionone.si) ---
MARKETING_CONTENT_URL=https://portal.visionone.si/api/marketing/content
MARKETING_MEDIA_BASE=https://portal.visionone.si
MARKETING_CONTENT_REVALIDATE_SEC=15
# Skrivnost za /api/revalidate-marketing (ista kot MARKETING_REVALIDATE_SECRET na portalu)
MARKETING_REVALIDATE_SECRET=
