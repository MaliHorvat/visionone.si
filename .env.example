# VisionOne portal — primer env spremenljivk
# Kopiraj v .env.local (lokalno) ali v Vercel → Settings → Environment Variables (produkcija).
# NE commitaj pravih ključev v git — samo placeholderji spodaj.

# --- PostgreSQL (Faza 1: Stranke / Paketi / Opomniki) ---
# Primer (Vercel Postgres / Neon / Supabase / lokalni):
# DATABASE_URL="postgresql://user:password@host:5432/visionone?sslmode=require"
DATABASE_URL=

# --- Clerk (legacy / sign-in stran) ---
# Trenutni portal uporablja interni login (admin / geslo123); Clerk je opcijski.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/portal
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal

# --- Piškotki / sledenje (javna marketing stran) ---
# Opcijsko: če prazno, se skripta ne naloži tudi ob soglasju.
# Meta Pixel (Facebook / Instagram oglasi)
NEXT_PUBLIC_META_PIXEL_ID=
# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# --- Kontaktni obrazec (ponudbe) — Resend API ---
# Ustvari ključ: https://resend.com/api-keys
# Domena pošiljatelja mora biti preverjena v Resend (npr. notifications@visionone.si).
RESEND_API_KEY=
# Kam pride obvestilo (samo en naslov; stranki se ne pošlje avtomatskega e-pisma).
CONTACT_FORM_TO=info@visionone.si
# Videti mora ustrezati preverjeni domeni, npr. "VisionOne <notifications@visionone.si>"
CONTACT_FORM_FROM=
